pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',   // ✅ Added
                    url: 'https://github.com/Rohitcs09/AI-DevOps.git'
            }
        }

        stage('Build with Maven') {
            steps {
                sh '''
                pwd
                ls -la

                cd ai-devops-project/ai-devops-maven

                echo "Running Maven Build..."

                mvn clean install > build.log 2>&1 || true

                echo "===== BUILD LOG ====="
                cat build.log

                echo "===== CHECKING FAILURE ====="

                if grep -q "BUILD FAILURE" build.log; then
                    echo "Build Failed"
                    
                else
                    echo "Build Success"
                fi
                '''
            }
        }

        stage('RUN AI Agent (Info Stage)') {
            steps {
                echo "AI Agent will run automatically if build fails"
            }
        }
    }

    post {
    failure {
        echo 'Build Failed - AI Analysis Triggered'

        withCredentials([usernamePassword(
            credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_PASS'
        )]) {

            sh '''
            echo "Running AI Agent..."
            cd ai-devops-project

            python3 --version || true
            pip3 install -r requirements.txt || true

            python3 ai_agent.py

            echo "Configuring Git..."
            git config user.email "jenkins@ai.com"
            git config user.name "Jenkins AI Bot"

            echo "Adding changes..."
            git add .

            echo "Committing fix..."
            git commit -m "AI auto-fix commit" || echo "Nothing to commit"

            echo "Pushing changes..."
            git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/AI-DevOps.git   # ✅ safer push
            git push origin main
            '''
        }
    }

    success {
        echo 'Build Success - No AI Analysis Needed'
    }
 }

}

