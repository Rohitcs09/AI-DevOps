pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Rohitcs09/AI-DevOps.git'
            }
        }

        stage('Build with Maven') {
            steps {
                sh '''
                cd ai-devops-project/ai-devops-maven

                echo "Running Maven Build..."

                mvn clean install > build.log 2>&1 || true

                echo "===== BUILD LOG ====="
                cat build.log

                echo "===== CHECKING FAILURE ====="

                if grep -q "BUILD FAILURE" build.log; then
                    echo "Build Failed"
                    exit 1
                else
                    echo "Build Success"
                fi
                '''
            }
        }

        stage('Run AI Agent') {
            steps {
                sh '''
                echo "Installing Python..."
                apt-get update -y
                apt-get install -y python3 python3-pip

                echo "Running AI Agent..."
                cd ai-devops-project
                python3 ai_agent.py
                '''
            }
        }
    }

    post {
        failure {
            echo ' Build Failed - AI Analysis Triggered'
        }
        success {
            echo 'Build Success'
        }
    }
}
