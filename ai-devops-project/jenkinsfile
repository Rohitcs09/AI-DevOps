pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Rohitcs09/AI-DevOps.git'
            }
        }

       stage('Build with Maven') {
    steps {
        sh '''
        cd ai-devops-project/ai-devops-maven

        echo "Running Maven Build..."

        # Run build and capture exit code
        mvn clean install | tee build.log
        BUILD_STATUS=${PIPESTATUS[0]}

        echo "===== BUILD STATUS ====="
        echo $BUILD_STATUS

        echo "===== BUILD LOG ====="
        cat build.log

        # 🔥 FINAL FAIL LOGIC
        if [ $BUILD_STATUS -ne 0 ]; then
            echo "Build Failed ❌"
            exit 1
        fi
        '''
    }
}

        // 👇 सिर्फ visibility के लिए (AI stage दिखे UI में)
        stage('AI Analysis (Info Stage)') {
            steps {
                echo "🤖 AI Agent will run automatically if build fails"
            }
        }
    }

    post {
        failure {
            echo '❌ Build Failed - AI Analysis Triggered'

            sh '''
            echo "Installing Python..."
            apt-get update -y
            apt-get install -y python3 python3-pip

            echo "🤖 Running AI Agent..."
            cd ai-devops-project
            python3 ai_agent.py
            '''
        }

        success {
            echo '✅ Build Success - No AI Analysis Needed'
        }
    }
}	
