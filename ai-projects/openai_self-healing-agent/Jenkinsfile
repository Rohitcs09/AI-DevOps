pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Build') {
    steps {
        sh '''
        cd ai-projects/openai_self-healing-agent/ai-devops-maven

        echo "📂 Current Path:"
        pwd

        echo "🚀 Running Maven Build..."

        # FORCE log creation
        mvn clean install > build.log 2>&1 || true

        echo "📂 Files after build:"
        ls -l

        echo "📄 Checking build.log:"
        if [ -f build.log ]; then
            echo "✅ build.log created"
            head -20 build.log
        else
            echo "❌ build.log NOT created"
        fi
        '''
    }
}
        stage('AI Debug') {
    steps {
        withCredentials([string(credentialsId: 'OPENAI_API_KEY', variable: 'OPENAI_API_KEY')]) {
            sh '''
            cd ai-projects/openai_self-healing-agent

            echo "📦 Installing dependencies (force)..."
            python3 -m pip install --break-system-packages openai python-dotenv

            export OPENAI_API_KEY=$OPENAI_API_KEY

            echo "🤖 Running AI Agent..."
            python3 ai-agent.py
            '''
        }
    }
}

        stage('Rebuild') {
            steps {
                sh '''
                cd ai-projects/openai_self-healing-agent/ai-devops-maven
                mvn clean install
                '''
            }
        }
    }
}
