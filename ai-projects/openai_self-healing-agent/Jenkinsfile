pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Build with Maven') {
    steps {
        script {
            def status = sh(script: '''
                cd ai-projects/openai_self-healing-agent/ai-devops-maven
                mvn clean install -U > build.log 2>&1
            ''', returnStatus: true)

            def log = readFile 'ai-projects/openai_self-healing-agent/ai-devops-maven/build.log'
            echo "===== BUILD LOG START ====="
            echo log
            echo "===== BUILD LOG END ====="

            if (status != 0) {
                echo "❌ Build Failed"
                writeFile file: 'ai-projects/openai_self-healing-agent/build_failed', text: 'failed'
            } else {
                echo "✅ Build Passed"
            }
        }
    }
}
        stage('AI Debug') {
    steps {
        withCredentials([string(credentialsId: 'OPENAI_API_KEY', variable: 'OPENAI_API_KEY')]) {
            sh '''
            cd ai-projects/openai_self-healing-agent

            echo "📦 Installing dependencies (force)..."
            python3 -m pip install --break-system-packages openai python-dotenv

            export OPENAI_API_KEY=$OPENAI_API_KEY

            echo "🤖 Running AI Agent..."
            python3 ai-agent.py
            '''
        }
    }
}

        stage('Rebuild After Fix') {
    when {
        expression {
            return fileExists('ai-projects/openai_self-healing-agent/build_failed')
        }
    }
    steps {
        script {
            def status = sh(script: '''
                cd ai-projects/openai_self-healing-agent/ai-devops-maven
                mvn clean install -U
            ''', returnStatus: true)

            if (status != 0) {
                error("❌ Build still failing after AI fix")
            } else {
                echo "✅ Build Fixed Successfully"
            }
        }
    }
}
}
