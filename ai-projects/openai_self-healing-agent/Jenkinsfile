pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                cd ai-devops-maven
                mvn clean install > build.log || true
                '''
            }
        }

        stage('AI Debug') {
            steps {
                withCredentials([string(credentialsId: 'OPENAI_API_KEY', variable: 'OPENAI_API_KEY')]) {
                    sh '''
                    export OPENAI_API_KEY=$OPENAI_API_KEY
                    python3 ai-agent.py
                    '''
                }
            }
        }

        stage('Rebuild') {
            steps {
                sh '''
                cd ai-devops-maven
                mvn clean install
                '''
            }
        }
    }
}
