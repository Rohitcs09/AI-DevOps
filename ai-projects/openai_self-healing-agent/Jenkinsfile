pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                cd ai-projects/openai_self-healing-agent/ai-devops-maven
                mvn clean install > build.log || true
                '''
            }
        }

        stage('AI Debug') {
    steps {
        withCredentials([string(credentialsId: 'OPENAI_API_KEY', variable: 'OPENAI_API_KEY')]) {
            sh '''
            cd ai-projects/openai_self-healing-agent

            echo "🐍 Creating venv..."
            python3 -m venv venv

            echo "⚙️ Activating venv..."
            . venv/bin/activate

            echo "📦 Installing dependencies..."
            pip install --upgrade pip
            pip install openai python-dotenv

            export OPENAI_API_KEY=$OPENAI_API_KEY

            echo "🤖 Running AI Agent..."
            python ai-agent.py
            '''
        }
    }
}

        stage('Rebuild') {
            steps {
                sh '''
                cd ai-projects/openai_self-healing-agent/ai-devops-maven
                mvn clean install
                '''
            }
        }
    }
}
